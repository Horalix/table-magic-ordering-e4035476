# Copy to .env and fill in. Only VITE_* vars reach the browser — never put
# secret keys here.

# --- Supabase (public, client-safe) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-ref
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-anon-publishable-key

# --- Monri card payments (front-end switch) ---
# Leave 'false' until the Monri Edge Function secrets are set + functions
# deployed. When 'true', checkout opens the secure Monri card form.
VITE_MONRI_ENABLED=false

# The MONRI server secrets below are NOT front-end vars. Set them as Supabase
# Edge Function secrets (Dashboard → Edge Functions → Secrets), never in .env:
#   MONRI_MERCHANT_KEY        (secret — never exposed to the browser)
#   MONRI_AUTHENTICITY_TOKEN
#   MONRI_ENVIRONMENT         = test | production
#   MONRI_CALLBACK_URL        = https://YOUR-PROJECT.functions.supabase.co/monri-webhook
#   MONRI_CURRENCY            = BAM   (optional, default BAM)
